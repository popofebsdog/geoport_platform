# 服務器配置
PORT=3001
NODE_ENV=development

# JWT 配置
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRES_IN=24h

# 文件上傳配置
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=50MB

# PostgreSQL 資料庫配置
DB_HOST=localhost
DB_PORT=5432
DB_NAME=geoport_db
DB_NAME_TEST=geoport_test
DB_USER=postgres
DB_PASSWORD=your-postgres-password
DB_SSL=false

# 資料庫連線池配置
DB_POOL_MAX=10
DB_POOL_MIN=0
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# Redis 配置 (可選，用於快取和會話)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# 郵件配置 (可選)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@geoport.com

# 檔案儲存配置
STORAGE_TYPE=local
# 如果使用雲端儲存
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=