# GeoPort cloud / Docker Compose environment

# Database
DB_NAME=geoport
DB_USER=geoport_user
DB_PASSWORD=replace-with-strong-password
DB_SSL=false

# Backend
JWT_SECRET=replace-with-strong-random-secret
JWT_EXPIRES_IN=24h
# Keep false in production unless you intentionally want public signup.
ALLOW_PUBLIC_REGISTRATION=false
FRONTEND_URL=https://your-domain.example
ALLOWED_ORIGINS=https://your-domain.example
TRUST_PROXY=1
TITILER_INTERNAL_URL=http://titiler:8000

# Storage
# local is implemented now. s3/gcs are reserved for future adapters.
STORAGE_PROVIDER=local
UPLOADS_ROOT=/app/uploads
DATA_ROOT=/app/data
UPLOADS_PUBLIC_PATH=/uploads
DATA_PUBLIC_PATH=/data
STORAGE_BUCKET=
STORAGE_REGION=
STORAGE_PUBLIC_BASE_URL=

# Optional host port overrides
HTTP_PORT=80
DB_PORT_PUBLISH=5432
TITILER_PORT=8080
