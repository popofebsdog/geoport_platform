# 伺服器
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173
TRUST_PROXY=false

# JWT（請使用強隨機值：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"）
JWT_SECRET=replace-with-strong-random-secret
JWT_EXPIRES_IN=24h
ALLOW_PUBLIC_REGISTRATION=false

# 資料庫（PostgreSQL）
DB_HOST=localhost
DB_PORT=5432
DB_NAME=geoport_db
DB_USER=postgres
DB_PASSWORD=replace-with-strong-password
DB_SSL=false

# TiTiler
TITILER_INTERNAL_URL=http://localhost:8080

# Storage abstraction
# local is implemented now. s3/gcs are reserved for future adapters.
STORAGE_PROVIDER=local
UPLOADS_ROOT=./uploads
DATA_ROOT=../data
UPLOADS_PUBLIC_PATH=/uploads
DATA_PUBLIC_PATH=/data
STORAGE_BUCKET=
STORAGE_REGION=
STORAGE_PUBLIC_BASE_URL=
